Secrets*.toml

# Environment / local config
.env
.env.*
!.env.example

# External ATP dataset (CC BY-NC-SA, re-downloadable from Jeff Sackmann's tennis_atp)
/data/raw/

# Editor / OS noise
/.idea/
/.vscode/
*.swp
.DS_Store
Thumbs.db
